#include <iostream>
#include <string>
#include <csignal>

#include "utils.h"
#include "consts.h"
#include "jobs.h"
#include "users.h"
#include "compops.h"


int main(int argc, char** argv) {
  std::string query = "squeue " + slurm::FORMAT_STRING;
  std::istringstream squeueout( slurm::utils::exec(query.c_str()) );
  slurm::Jobs jobs;
  squeueout >> jobs;

  slurm::UserStats userstats (jobs);
  std::sort(userstats.begin(), userstats.end(), slurm::CompareNRunning);

  std::cout << userstats << std::endl;
  return 0;
}
